{
  "name": "AlmaMod → Redes Sociales",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": "",
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": -183, "y": 0 },
        "restore": {
          "parameters": {
            "hook": {
              "label": "AlmaMod Webhook",
              "data": { "editable": "true" }
            }
          }
        }
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicRouter",
      "version": 1,
      "parameters": {},
      "mapper": {},
      "metadata": { "designer": { "x": 150, "y": 0 } },
      "routes": [
        {
          "flow": [],
          "metadata": {
            "designer": { "x": 450, "y": -160 },
            "name": "Reel",
            "filter": {
              "name": "tipo = reel",
              "conditions": [
                [{ "a": "{{1.tipo}}", "b": "reel", "o": "text:equal" }]
              ]
            }
          }
        },
        {
          "flow": [],
          "metadata": {
            "designer": { "x": 450, "y": 160 },
            "name": "Post / Libre",
            "filter": {
              "name": "tipo != reel",
              "conditions": [
                [{ "a": "{{1.tipo}}", "b": "reel", "o": "text:notEqual" }]
              ]
            }
          }
        }
      ]
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": { "orphans": [] },
    "zone": "eu1.make.com"
  }
}
